    {"name": "internet_google", "host": "8.8.8.8"},
    {"name": "internet_cloudflare", "host": "1.1.1.1"}
  ],
  "tcp_targets": [
    {"name": "router_dns", "host": "192.168.181.1", "port": 53},
    {"name": "adguard_dns", "host": "192.168.181.5", "port": 53},
    {"name": "adguard_dns_tls", "host": "192.168.181.5", "port": 853},
    {"name": "adguard_dns_https", "host": "192.168.181.5", "port": 443},
    {"name": "cloudflare_https", "host": "1.1.1.1", "port": 443}
  ]
