{
  "interval_seconds": 30,
  "dns_timeout_seconds": 2.0,
  "tcp_timeout_seconds": 2.0,
  "ping_count": 1,
  "ping_timeout_seconds": 2,
  "dns_servers": ["192.168.181.5", "8.8.8.8"],
  "dns_probe_host": "example.com",
  "latency_targets": [
    {"name": "router", "host": "192.168.181.1"},
